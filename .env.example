# =============================================================
# OmniNode Infrastructure Manager — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# BITCOIN NODE
# -------------------------------------------------------------
BTC_RPC_USER=omninode_btc
BTC_RPC_PASS=changeme_strong_password
BTC_RPC_PORT=8332
BTC_P2P_PORT=8333
BTC_NETWORK=testnet

# -------------------------------------------------------------
# ETHEREUM NODE
# -------------------------------------------------------------
ETH_HTTP_PORT=8545
ETH_WS_PORT=8546
ETH_P2P_PORT=30303
ETH_METRICS_PORT=6060
ETH_NETWORK=sepolia

# -------------------------------------------------------------
# MONITORING — PROMETHEUS
# -------------------------------------------------------------
PROMETHEUS_PORT=9090

# -------------------------------------------------------------
# MONITORING — GRAFANA
# -------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_PASSWORD=changeme_strong_password

# -------------------------------------------------------------
# MONITORING — ALERTMANAGER
# -------------------------------------------------------------
ALERTMANAGER_PORT=9093

# -------------------------------------------------------------
# ALERTING — DISCORD / SLACK
# -------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_HERE

# -------------------------------------------------------------
# GENERAL
# -------------------------------------------------------------
COMPOSE_PROJECT_NAME=omninode
LOG_LEVEL=info

# -------------------------------------------------------------
# LIGHTHOUSE BEACON CLIENT
# -------------------------------------------------------------
LIGHTHOUSE_P2P_PORT=9000
LIGHTHOUSE_HTTP_PORT=5052
